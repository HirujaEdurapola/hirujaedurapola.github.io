    <div class="hello">
        <img src="./img/pfp.jpeg" alt="Hiruja Edurapola" class="hello-img" draggable="false">
        <h1 class="hello-text">hello, i'm hiruja</h1>
    </div>

    <div class="links" id="socials">
        <!-- <div class="link-txt">
            <h1 class="link-topic">My Socials</h1>
        </div> -->
        <div class="link-boxes">
            <div class="link-box" onclick="openHiruja(`https://github.com/HirujaEdurapola/`)">
                <git class="link-icon"></git>
                <h1 class="link-box-item">Github</h1>
            </div>
            <div class="link-box" onclick="openHiruja(`https://www.youtube.com/@HirujaEdurapola/`)">
                <yt class="link-icon"></yt>
                <h1 class="link-box-item">Youtube</h1>
            </div>
        </div>
    </div>
    <div class="large-div">
        <div class="age-div">
            <h1 class="age-txt-head">I am</h1>
        </div>
        <div class="age">
            <div class="age-box">
                <div id="age-card">
                    <h1 id="years">00</h1>
                </div>
                <div id="age-card">
                    <h1 id="months">00</h1>
                </div>
                <div id="age-card">
                    <h1 id="days">00</h1>
                </div>
                <div id="age-card">
                    <h1 id="hours">00</h1>
                </div>
                <div id="age-card">
                    <h1 id="minutes">00</h1>
                </div>
                <div id="age-card">
                    <h1 id="seconds">00</h1>
                </div>
                <h1 class="age-txt">Years</h1>
                <h1 class="age-txt">Months</h1>
                <h1 class="age-txt">Days</h1>
                <h1 class="age-txt">Hours</h1>
                <h1 class="age-txt">Minutes</h1>
                <h1 class="age-txt">Seconds</h1>
            </div>
            <div class="txt-mobile">
                <h1 class="age-txts">Years</h1>
                <h1 class="age-txts">Months</h1>
                <h1 class="age-txts">Days</h1>
                <h1 class="age-txts">Hours</h1>
                <h1 class="age-txts">Minutes</h1>
                <h1 class="age-txts">Seconds</h1>
            </div>
        </div>
        <div class="age-div">
            <h1 class="age-txt-head">Old</h1>
        </div>
    </div>

